  "info": {
    "_postman_id": "326b5157-ead9-441d-89cd-94cdb99b7892",
    "name": "Shopify Multipass API",
    "description": "Multipass login enables seamless single sign-on for Shopify Plus stores. It allows store owners who have a separate website and a Shopify store to redirect users from the external website and automatically log them into the Shopify store. Multipass tokens are generated server-side using AES encryption and HMAC signing with the store multipass secret, then passed to the Shopify login endpoint via URL. Tokens are valid for 15 minutes and can only be used once. Requires a Shopify Plus plan.\n\nContact Support:\n Name: Shopify\n Email: api@shopify.com",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "createdAt": "2026-06-05T13:18:44.000Z",
    "updatedAt": "2026-06-05T13:18:44.000Z",
