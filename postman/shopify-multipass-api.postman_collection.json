                      "name": "Shopify Log in a customer using a Multipass token",
                      "id": "dae09267-8761-40f5-905b-12e8886ed988",
                      "protocolProfileBehavior": {
                        "disableBodyPruning": true
                      },
                      "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                          "raw": "{{baseUrl}}/account/login/multipass/:token",
                          "host": [
                            "{{baseUrl}}"
                          ],
                          "path": [
                            "account",
                            "login",
                            "multipass",
                            ":token"
                          ],
                          "variable": [
                            {
                              "id": "6092eb5e-1322-4cdc-914b-74efd1f46dc7",
                              "key": "token",
                              "value": "<string>",
                              "description": "(Required) The encrypted and signed Multipass token. Generated by encrypting a JSON payload containing at minimum an email address, then Base64 URL-encoding the result."
                            }
                          ]
                        },
                        "description": "Authenticates a customer using a Multipass token. The token is generated server-side by encrypting a JSON customer payload with AES-128-CBC and signing it with HMAC-SHA256 using keys derived from the store Multipass secret. The token is valid for 15 minutes and can only be used once. On success the customer is logged in and redirected to the return_to URL or the store homepage."
                      },
